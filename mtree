#------------------------------------------------------------------------------
# Dispatch
#------------------------------------------------------------------------------
# Pull global flags out of the args; leave positionals for the command.
OPT_BASE=""; OPT_PLATFORM=""; OPT_NOBOOTSTRAP=""; OPT_JSON=""; OPT_FORCE=""
_args=()
while (($#)); do
  case "$1" in
    --base) OPT_BASE="${2:?--base needs a value}"; shift 2 ;;
    --base=*) OPT_BASE="${1#*=}"; shift ;;
    --mobile) OPT_PLATFORM=mobile; shift ;;
    --web) OPT_PLATFORM=web; shift ;;
    --no-bootstrap) OPT_NOBOOTSTRAP=1; shift ;;
    --json) OPT_JSON=1; shift ;;
    --force|-f) OPT_FORCE=1; shift ;;
    --) shift; while (($#)); do _args+=("$1"); shift; done ;;
    *) _args+=("$1"); shift ;;
  esac
done
set -- ${_args[@]+"${_args[@]}"}

# bare `mwt` in a terminal → welcome banner + interactive prompt (Claude-CLI style);
# `mwt <cmd> …` still runs once and exits, so scripts/aliases are unaffected.
# In a real terminal (and not a nested one-shot launched from the REPL) ALWAYS run interactively:
# `mtree` opens the session; `mwt <cmd>` opens it and runs <cmd> as the first command inside it.
# EXCEPT `claude`: it hands the TTY to a full-screen app, so it must bypass our alt-screen REPL
# (nesting two alt-screens corrupts the display) — fall straight through to the dispatch below.
if [[ -z "${MWT_NESTED:-}" && -t 0 && -t 1 && "${1:-}" != "claude" ]]; then
  _enter_interactive "$@"
  exit 0
fi
# Nested REPL command, a pipe, or a script → run a single command and exit.
cmd="${1:-banner}"; shift || true
case "$cmd" in
  work)          if [[ "${1:-}" == "init" ]]; then cmd_init; else cmd_work "$@"; fi ;;
  init)          cmd_init ;;
  remove|rm)     cmd_remove "$@" ;;
  resume|continue|cont) cmd_resume "$@" ;;
  hotfix)        cmd_hotfix "$@" ;;
  review)        cmd_review "$@" ;;
  scratch)       cmd_scratch "$@" ;;
  mobile)        cmd_mobile "$@" ;;
  batch)         cmd_batch "$@" ;;
  types)         cmd_types ;;
  ls|list)       cmd_ls "$@" ;;
  path|go)       cmd_path "$@" ;;
  claude)        cmd_claude "$@" ;;
  bootstrap)     bootstrap "$@" ;;
  sync-env)      cmd_sync_env "$@" ;;
  cleanup)       cmd_cleanup "$@" ;;
  doctor)        cmd_doctor "$@" ;;
  banner)        cmd_banner ;;
  shell|repl)    _enter_interactive "$@" ;;
  help|-h|--help) cmd_help ;;
  *) if _type_row "$cmd" >/dev/null 2>&1; then cmd_work "$cmd" "$@";
     else die "Unknown command/type: $cmd  (run '$(self) help')"; fi ;;
esac
